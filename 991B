#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

int main() {
    int n;
    cin >> n;

    vector<int> a(n);
    int sum = 0;

    for(int i = 0; i < n; i++){
        cin >> a[i];
        sum += a[i];
    }

    sort(a.begin(), a.end());

    int count = 0;

    for(int i = 0; i < n; i++){
        double avg = (double)sum / n;

        if(avg >= 4.5)
            break;

        sum = sum - a[i] + 5;
        count++;
    }

    cout << count << endl;
}
