#include <iostream>
using namespace std;

int main() {
    int t;
    cin >> t;
    
    while(t--) {
        int n;
        cin >> n;
        string s;
        cin >> s;
        
        int balance = 0;
        int moves = 0;
        
        for(char c : s) {
            if(c == '(') {
                balance++;
            } else {
                balance--;
            }
            
            if(balance < 0) {
                moves++;
                balance = 0;
            }
        }
        
        cout << moves << endl;
    }
    
    return 0;
}
