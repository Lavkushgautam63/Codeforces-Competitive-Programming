#include <bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin >> t;

    while (t--) {
        int n, m, x, y;
        cin >> n >> m >> x >> y;

        vector<string> grid(n);
        for (int i = 0; i < n; i++) {
            cin >> grid[i];
        }

        long long cost = 0;

        for (int i = 0; i < n; i++) {
            for (int j = 0; j < m; ) {
                if (grid[i][j] == '*') {
                    j++;
                } else {
                    if (j + 1 < m && grid[i][j + 1] == '.' && y < 2 * x) {
                        cost += y;
                        j += 2;
                    } else {
                        cost += x;
                        j += 1;
                    }
                }
            }
        }

        cout << cost << "\n";
    }

    return 0;
}
