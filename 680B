#include <bits/stdc++.h>
using namespace std;

int main() {
    int n, a;
    cin >> n >> a;

    vector<int> t(n + 1);
    for (int i = 1; i <= n; i++) {
        cin >> t[i];
    }

    int ans = 0;

    for (int d = 0; d < n; d++) {
        int left = a - d;
        int right = a + d;

        if (left >= 1 && right <= n) {
            if (t[left] == 1 && t[right] == 1) {
                if (left == right) ans += 1;
                else ans += 2;
            }
        } else if (left >= 1) {
            if (t[left] == 1) ans += 1;
        } else if (right <= n) {
            if (t[right] == 1) ans += 1;
        }
    }

    cout << ans;
    return 0;
}
