#include <bits/stdc++.h>
using namespace std;

int main() {
    long long n, m;
    cin >> n >> m;

    vector<long long> task(m);
    for (int i = 0; i < m; i++) {
        cin >> task[i];
    }

    long long current = 1;
    long long time = 0;

    for (int i = 0; i < m; i++) {
        if (task[i] >= current) {
            time += (task[i] - current);
        } else {
            time += (n - current + task[i]);
        }
        current = task[i];
    }

    cout << time << endl;

    return 0;
}
