#include <bits/stdc++.h>
using namespace std;

int main() {
    int n;
    cin >> n;

    string s;
    cin >> s;

    if (n > 26) {
        cout << -1;
        return 0;
    }

    vector<int> freq(26, 0);

    for (char ch : s) {
        freq[ch - 'a']++;
    }

    int changes = 0;

    for (int i = 0; i < 26; i++) {
        if (freq[i] > 1) {
            changes += (freq[i] - 1);
        }
    }

    cout << changes;

    return 0;
}
