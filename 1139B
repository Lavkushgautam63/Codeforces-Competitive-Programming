#include <bits/stdc++.h>
using namespace std;

int main() {
    int n;
    cin >> n;

    vector<long long> a(n);
    for(int i = 0; i < n; i++)
        cin >> a[i];

    long long ans = 0;
    long long next = 1e18;

    for(int i = n-1; i >= 0; i--) {
        long long take = min(a[i], next - 1);
        if(take <= 0) break;

        ans += take;
        next = take;
    }

    cout << ans;
}
