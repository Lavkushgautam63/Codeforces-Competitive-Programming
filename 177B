#include <bits/stdc++.h>
using namespace std;

int main() {
    long long n;
    cin >> n;

    long long sum = 0;

    while (n > 1) {
        sum += n;

        long long d = 2;
        for (long long i = 2; i * i <= n; i++) {
            if (n % i == 0) {
                d = i;
                break;
            }
        }

        if (d == 2 && n % 2 != 0) d = n;

        n /= d;
    }

    sum += 1;

    cout << sum;
}
