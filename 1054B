#include <bits/stdc++.h>
using namespace std;

int main() {
    int n;
    cin >> n;

    vector<int> a(n);
    for(int i = 0; i < n; i++) cin >> a[i];

    if(a[0] != 0) {
        cout << 1 << endl;
        return 0;
    }

    set<int> s;
    int mex = 0;

    for(int i = 0; i < n; i++) {
        s.insert(a[i]);

        while(s.count(mex)) mex++;

        if(a[i] > mex) {
            cout << i + 1 << endl;
            return 0;
        }
    }

    cout << -1 << endl;
}
