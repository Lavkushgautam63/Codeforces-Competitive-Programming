#include <bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin >> t;

    while(t--) {
        int n;
        cin >> n;

        vector<int> a(n);
        for(int i = 0; i < n; i++) cin >> a[i];

        sort(a.begin(), a.end());

        int ans = 1;

        for(int i = 0; i < n; i++) {
            int k = i + 2;
            if(a[i] <= i + 1) ans = k;
        }

        cout << ans << "\n";
    }

    return 0;
}
