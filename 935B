#include <iostream>
using namespace std;

int main() {
    int n;
    string s;
    
    cin >> n;
    cin >> s;

    int x = 0, y = 0;
    int coins = 0;

    for(int i = 0; i < n-1; i++) {
        if(s[i] == 'R')
            x++;
        else
            y++;

        if(x == y && s[i] == s[i+1]) {
            coins++;
        }
    }

    cout << coins << endl;

    return 0;
}
