#include <bits/stdc++.h>
using namespace std;

int main(){
    long long n;
    int m;
    cin >> n >> m;

    vector<long long> a(m);
    for(int i=0;i<m;i++) cin >> a[i];

    sort(a.begin(),a.end());

    if(m && (a[0]==1 || a[m-1]==n)){
        cout<<"NO";
        return 0;
    }

    for(int i=0;i<m-2;i++){
        if(a[i]+1==a[i+1] && a[i]+2==a[i+2]){
            cout<<"NO";
            return 0;
        }
    }

    cout<<"YES";
}
