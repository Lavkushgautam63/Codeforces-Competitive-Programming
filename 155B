#include <bits/stdc++.h>
using namespace std;

int main() {
    int n;
    cin >> n;

    vector<pair<int,int>> v(n);

    for(int i = 0; i < n; i++) {
        cin >> v[i].first >> v[i].second;
    }

    sort(v.begin(), v.end(), [](pair<int,int> a, pair<int,int> b) {
        if(a.second == b.second)
            return a.first > b.first;
        return a.second > b.second;
    });

    int counter = 1;
    int points = 0;

    for(int i = 0; i < n; i++) {
        if(counter == 0) break;

        points += v[i].first;
        counter += v[i].second;
        counter--;
    }

    cout << points;

    return 0;
}
